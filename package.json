{
  "name": "dev-dashboard-api",
  "version": "0.1.0",
  "bin": {
    "dev-dashboard-api": "dist/bin/App.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "test:unit": "jest --config jest.unit.config.ts",
    "lint": "eslint '**/*.ts'",
    "lint:fix": "eslint '**/*.ts' --fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "cdk": "cdk",
    "generate:sam": "npx ts-node scripts/generate-sam-template.ts",
    "generate:postman": "npx ts-node scripts/generate-postman-collection.ts",
    "deploy": "npx cdk deploy --all --require-approval never",
    "destroy": "npx cdk destroy --all --force",
    "dev": "bash scripts/dev.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/jest": "^30",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "aws-cdk": "2.1106.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.3",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-plugin-import": "^2",
    "eslint-plugin-prettier": "^5",
    "husky": "^9.1.7",
    "jest": "^30",
    "nodemon": "^3.1.14",
    "prettier": "^3",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "aws-cdk-lib": "^2.238.0",
    "constructs": "^10.0.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.18.0",
    "zod": "^4.3.6"
  }
}
