    "@typescript-eslint/parser": "^8",
    "aws-cdk": "2.1106.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-plugin-import": "^2",
    "eslint-plugin-prettier": "^5",
    "jest": "^30",
    "nodemon": "^3.1.14",
    "prettier": "^3",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "wait-on": "^9.0.4"
